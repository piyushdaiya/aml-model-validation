generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email            String    @unique
  username         String    @unique
  password         String
  name             String
  role             String
  department       String?
  phone            String?
  location         String?
  avatarUrl        String?
  status           String    @default("active")
  twoFactorEnabled Boolean   @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cases            Case[]
  alerts           Alert[]
}

model Case {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String
  priority    String
  assignedTo  User?    @relation(fields: [userId], references: [id])
  userId      String?
  partyId     String?
  party       Party?   @relation(fields: [partyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  alerts      Alert[]
}

model Alert {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  status      String
  priority    String
  assignedTo  User?    @relation(fields: [userId], references: [id])
  userId      String?
  case        Case?    @relation(fields: [caseId], references: [id])
  caseId      String?
  partyId     String?
  party       Party?   @relation(fields: [partyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Party {
  id           String        @id @default(cuid())
  name         String
  type         String
  status       String
  riskLevel    String
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cases        Case[]
  alerts       Alert[]
  accounts     Account[]
  address      Address[]
  transactions Transaction[]
}

model Account {
  id            String        @id @default(cuid())
  accountNumber String        @unique
  type         String
  subType      String?
  status       String
  balance      Float
  currency     String
  party        Party         @relation(fields: [partyId], references: [id])
  partyId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Address {
  id        String   @id @default(cuid())
  street    String
  city      String
  state     String?
  zipCode   String
  country   String
  type      String   @default("primary")
  party     Party    @relation(fields: [partyId], references: [id])
  partyId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  currency    String
  type        String
  status      String
  description String?
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   String
  party       Party    @relation(fields: [partyId], references: [id])
  partyId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Rule {
  id            String    @id @default(cuid())
  name          String
  description   String
  type          String    // "Pre-scoring" | "Reject" | "Put on hold"
  category      String    // "Transaction Monitoring" | "Customer Risk" | "Sanction Screening"
  bundle        String
  score         Int
  status        String    @default("active")
  parameters    Json?     // Store rule parameters as JSON
  tags          String[]  // Array of tags
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  modelId       String?   // Optional reference to a Model
  model         Model?    @relation(fields: [modelId], references: [id])
}

model Model {
  id            String    @id @default(cuid())
  name          String
  description   String
  type          String    // "Transaction Monitoring" | "Customer Risk" | "Sanctions Screening"
  version       String
  status        String    @default("active")
  rules         Rule[]
  mlModels      MLModel[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MLModel {
  id            String    @id @default(cuid())
  name          String
  description   String
  version       String
  type          String    // "Classification" | "Regression" | "Clustering"
  format        String    // "TensorFlow" | "PyTorch" | "Scikit-learn"
  parameters    Json      // Store model parameters as JSON
  features      String[]  // Array of feature names
  performance   Json      // Store performance metrics as JSON
  status        String    @default("active")
  modelId       String?   // Optional reference to a Model
  model         Model?    @relation(fields: [modelId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
